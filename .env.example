# ── LLM (brief generation) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# MODEL=claude-sonnet-4-6

# ── Real X data (Phase 2 spike) ──────────────────────────────────────────
# Get a token at apify.com → Settings → Integrations → API tokens
APIFY_TOKEN=apify_api_...
# Actor to run (default: apidojo~tweet-scraper). Swap for your chosen X scraper.
APIFY_ACTOR=apidojo~tweet-scraper
# Cap items per run during the spike (cost control)
APIFY_MAX_ITEMS=100

# ── Provider selection for `npm run analyze` ─────────────────────────────
# sample (default, free) | apify (real data, needs APIFY_TOKEN)
PROVIDER=sample
# Limit how many tracked accounts to scan (cost control during the spike)
MAX_ACCOUNTS=3
